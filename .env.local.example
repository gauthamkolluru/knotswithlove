# ─── Sanity project (required) ────────────────────────────────────────────────
# Get these from https://sanity.io/manage after creating your project.
NEXT_PUBLIC_SANITY_PROJECT_ID=your_project_id_here
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=2024-01-01

# ─── Revalidation webhook secret (required) ───────────────────────────────────
# Choose any random string. You'll enter this in Sanity webhook settings too.
SANITY_REVALIDATE_SECRET=your_random_secret_here
